{% extends 'dashboard/base.html.twig' %}

{% block title %}Profile - Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/dashboard-page.css') }}">
    <style>
        .profile-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .profile-card {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 20px;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 32px;
            font-weight: bold;
        }

        .profile-info h1 {
            margin: 0;
            color: #333;
            font-size: 24px;
        }

        .profile-role {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }

        .profile-field {
            margin-bottom: 20px;
        }

        .profile-label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            display: block;
        }

        .profile-value {
            color: #666;
            padding: 12px;
            background: #f9f9f9;
            border-radius: 6px;
            border-left: 3px solid #667eea;
        }

        .profile-actions {
            display: flex;
            gap: 10px;
            margin-top: 30px;
        }

        .btn {
            padding: 10px 20px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background: #5568d3;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: #e0e0e0;
            color: #333;
        }

        .btn-secondary:hover {
            background: #d0d0d0;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 14px;
            transition: border-color 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .form-errors {
            color: #dc2626;
            font-size: 12px;
            margin-top: 5px;
        }

        .form-errors ul {
            margin: 0;
            padding-left: 20px;
        }

        @media (max-width: 600px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block header_title %}Profile{% endblock %}

{% block dashboard_content %}
<div class="dashboard-page-content">
    <div class="profile-container">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar">{{ user.getDisplayName()|slice(0, 2)|upper }}</div>
                <div class="profile-info">
                    <h1>{{ user.getDisplayName() }}</h1>
                    <div class="profile-role">
                        {% if user.isAdmin() %}
                            Administrator
                        {% elseif user.isStaff() %}
                            Staff Member
                        {% else %}
                            User
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="info-grid">
                <div class="profile-field">
                    <label class="profile-label">Email Address</label>
                    <div class="profile-value">{{ user.getEmail() }}</div>
                </div>

                <div class="profile-field">
                    <label class="profile-label">Full Name</label>
                    <div class="profile-value">Not available</div>
                </div>

                <div class="profile-field">
                    <label class="profile-label">User ID</label>
                    <div class="profile-value">#{{ user.getId() }}</div>
                </div>

                <div class="profile-field">
                    <label class="profile-label">Account Status</label>
                    <div class="profile-value" style="border-left-color: #4ade80;">
                        <span style="display: inline-block; width: 8px; height: 8px; background: #4ade80; border-radius: 50%; margin-right: 8px;"></span>Active
                    </div>
                </div>
            </div>

            <div class="profile-actions">
                <button class="btn btn-primary" onclick="document.getElementById('editForm').style.display = 'block'">Edit Profile</button>
                <a href="{{ path('app_dashboard_settings') }}" class="btn btn-secondary">Go to Settings</a>
            </div>
        </div>

        <div id="editForm" class="profile-card" style="display: none;">
            <h2 style="margin-top: 0; margin-bottom: 25px; color: #333;">Edit Profile</h2>
            {{ form_start(form, {'attr': {'class': 'profile-edit-form'}}) }}
            
            <div class="form-group">
                {{ form_label(form.email, 'Email Address', {'label_attr': {'class': 'profile-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {% if form.email.vars.errors|length > 0 %}
                    <div class="form-errors">
                        {{ form_errors(form.email) }}
                    </div>
                {% endif %}
            </div>

            <div class="profile-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('editForm').style.display = 'none'">Cancel</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}


