{% extends 'dashboard/base.html.twig' %}

{% block title %}Add New Apartment - Rental Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <style>
        .new-apartment-container {
            padding: 20px;
            max-width: 900px;
            margin: 0 auto;
        }

        .page-header {
            margin-bottom: 30px;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: #333;
            margin: 0;
        }

        .form-container {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .form-section {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f0f0f0;
        }

        .form-section:last-of-type {
            border-bottom: none;
        }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #333;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            transition: border-color 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 14px;
        }

        .btn-primary {
            background: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background: #5568d3;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background: #e0e0e0;
            color: #333;
        }

        .btn-secondary:hover {
            background: #d0d0d0;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 2px solid #f0f0f0;
        }

        .form-errors {
            background: #fee2e2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .form-errors ul {
            margin: 0;
            padding-left: 20px;
        }

        .field-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 5px;
        }

        @media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .form-actions {
                flex-direction: column;
            }

            .form-actions .btn {
                width: 100%;
                text-align: center;
            }
        }
    </style>
{% endblock %}

{% block header_title %}Add New Apartment{% endblock %}

{% block dashboard_content %}
<div class="new-apartment-container">
    <div class="page-header">
        <h1 class="page-title">➕ Add New Apartment</h1>
    </div>

    <div class="form-container">
        {{ form_start(form, {'attr': {'class': 'form-horizontal'}}) }}

            <div class="form-section">
                <h3 class="section-title">Apartment Details</h3>
                <div class="form-row">
                    <div class="form-group">
                        {{ form_label(form.name, 'Name') }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                        {% if form.name.vars.errors|length > 0 %}
                            <div class="field-error">{% for error in form.name.vars.errors %}{{ error.message }}{% endfor %}</div>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.address, 'Address') }}
                        {{ form_widget(form.address, {'attr': {'class': 'form-control'}}) }}
                        {% if form.address.vars.errors|length > 0 %}
                            <div class="field-error">{% for error in form.address.vars.errors %}{{ error.message }}{% endfor %}</div>
                        {% endif %}
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div class="form-group">
                        {{ form_label(form.bedrooms, 'Bedrooms') }}
                        {{ form_widget(form.bedrooms, {'attr': {'class': 'form-control'}}) }}
                        {% if form.bedrooms.vars.errors|length > 0 %}
                            <div class="field-error">{% for error in form.bedrooms.vars.errors %}{{ error.message }}{% endfor %}</div>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.bathrooms, 'Bathrooms') }}
                        {{ form_widget(form.bathrooms, {'attr': {'class': 'form-control'}}) }}
                        {% if form.bathrooms.vars.errors|length > 0 %}
                            <div class="field-error">{% for error in form.bathrooms.vars.errors %}{{ error.message }}{% endfor %}</div>
                        {% endif %}
                    </div>
                </div>

                <div class="form-group">
                    {{ form_label(form.rentAmount, 'Rent Amount') }}
                    {{ form_widget(form.rentAmount, {'attr': {'class': 'form-control'}}) }}
                    {% if form.rentAmount.vars.errors|length > 0 %}
                        <div class="field-error">{% for error in form.rentAmount.vars.errors %}{{ error.message }}{% endfor %}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    {{ form_label(form.status, 'Status') }}
                    {{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
                    {% if form.status.vars.errors|length > 0 %}
                        <div class="field-error">{% for error in form.status.vars.errors %}{{ error.message }}{% endfor %}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-section">
                <h3 class="section-title">Additional</h3>
                <div class="form-group">
                    {{ form_label(form.description, 'Description') }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.image, 'Image') }}
                    {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.image) }}
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('app_apartment_index') }}" class="btn btn-secondary">Cancel</a>
                {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}}) }}
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function(){
        const form = document.querySelector('form');
        if (!form) return;

        // Client-side validation for negative values
        const rentAmountInput = form.querySelector('input[name="apartment[rentAmount]"]');
        const bedroomsInput = form.querySelector('input[name="apartment[bedrooms]"]');
        const bathroomsInput = form.querySelector('input[name="apartment[bathrooms]"]');

        function validatePositive(input, fieldName, minValue = 0) {
            if (!input) return;
            
            input.addEventListener('input', function(e) {
                const value = parseFloat(e.target.value);
                if (isNaN(value) || value < minValue) {
                    e.target.setCustomValidity(fieldName + ' cannot be negative' + (minValue > 0 ? ' and must be at least ' + minValue : '') + '.');
                    e.target.reportValidity();
                } else {
                    e.target.setCustomValidity('');
                }
            });

            input.addEventListener('blur', function(e) {
                const value = parseFloat(e.target.value);
                if (isNaN(value) || value < minValue) {
                    e.target.setCustomValidity(fieldName + ' cannot be negative' + (minValue > 0 ? ' and must be at least ' + minValue : '') + '.');
                    e.target.reportValidity();
                } else {
                    e.target.setCustomValidity('');
                }
            });
        }

        validatePositive(rentAmountInput, 'Rent amount', 0);
        validatePositive(bedroomsInput, 'Number of bedrooms', 1);
        validatePositive(bathroomsInput, 'Number of bathrooms', 1);

        form.addEventListener('submit', function(e){
            let hasError = false;

            if (rentAmountInput) {
                const value = parseFloat(rentAmountInput.value);
                if (isNaN(value) || value < 0) {
                    e.preventDefault();
                    rentAmountInput.setCustomValidity('Rent amount cannot be negative.');
                    rentAmountInput.reportValidity();
                    hasError = true;
                }
            }

            if (bedroomsInput) {
                const value = parseInt(bedroomsInput.value);
                if (isNaN(value) || value < 1) {
                    e.preventDefault();
                    bedroomsInput.setCustomValidity('Number of bedrooms must be at least 1.');
                    bedroomsInput.reportValidity();
                    hasError = true;
                }
            }

            if (bathroomsInput) {
                const value = parseInt(bathroomsInput.value);
                if (isNaN(value) || value < 1) {
                    e.preventDefault();
                    bathroomsInput.setCustomValidity('Number of bathrooms must be at least 1.');
                    bathroomsInput.reportValidity();
                    hasError = true;
                }
            }

            if (hasError) {
                return;
            }
        });
    })();
    </script>
{% endblock %}
