{% extends 'dashboard/base.html.twig' %}

{% block title %}Edit {{ apartment.name }} - Rental Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <style>
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 2rem;
            color: #20b2aa;
            margin-bottom: 10px;
        }

        .form-container {
            background: white;
            border-radius: 10px;
            padding: 30px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #333;
        }

        .form-control {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 1rem;
        }

        .form-control:focus {
            outline: none;
            border-color: #20b2aa;
            box-shadow: 0 0 0 2px rgba(32, 178, 170, 0.2);
        }

        .btn {
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: #20b2aa;
            color: white;
        }

        .btn-primary:hover {
            background: #008b8b;
        }

        .btn-secondary {
            background: #6c757d;
            color: white;
        }

        .btn-secondary:hover {
            background: #5a6268;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }
    </style>
{% endblock %}

{% block header_title %}Edit {{ apartment.name }}{% endblock %}

{% block dashboard_content %}
<div class="container">
    <div class="page-header">
        <h1 class="page-title">Edit {{ apartment.name }}</h1>
    </div>

    <div class="form-container">
        {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.address) }}
                {{ form_widget(form.address) }}
                {{ form_errors(form.address) }}
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    {{ form_label(form.bedrooms) }}
                    {{ form_widget(form.bedrooms) }}
                    {{ form_errors(form.bedrooms) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.bathrooms) }}
                    {{ form_widget(form.bathrooms) }}
                    {{ form_errors(form.bathrooms) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.rentAmount) }}
                {{ form_widget(form.rentAmount) }}
                {{ form_errors(form.rentAmount) }}
            </div>

            <div class="form-group">
                {{ form_label(form.status) }}
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-group">
                {{ form_label(form.image) }}
                {{ form_widget(form.image) }}
                {{ form_errors(form.image) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('app_apartment_show', {'id': apartment.id}) }}" class="btn btn-secondary">Cancel</a>
                {{ form_widget(form.save) }}
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function(){
        const form = document.querySelector('form');
        if (!form) return;

        // Client-side validation for negative values
        const rentAmountInput = form.querySelector('input[name="apartment[rentAmount]"]');
        const bedroomsInput = form.querySelector('input[name="apartment[bedrooms]"]');
        const bathroomsInput = form.querySelector('input[name="apartment[bathrooms]"]');

        function validatePositive(input, fieldName, minValue = 0) {
            if (!input) return;
            
            input.addEventListener('input', function(e) {
                const value = parseFloat(e.target.value);
                if (isNaN(value) || value < minValue) {
                    e.target.setCustomValidity(fieldName + ' cannot be negative' + (minValue > 0 ? ' and must be at least ' + minValue : '') + '.');
                    e.target.reportValidity();
                } else {
                    e.target.setCustomValidity('');
                }
            });

            input.addEventListener('blur', function(e) {
                const value = parseFloat(e.target.value);
                if (isNaN(value) || value < minValue) {
                    e.target.setCustomValidity(fieldName + ' cannot be negative' + (minValue > 0 ? ' and must be at least ' + minValue : '') + '.');
                    e.target.reportValidity();
                } else {
                    e.target.setCustomValidity('');
                }
            });
        }

        validatePositive(rentAmountInput, 'Rent amount', 0);
        validatePositive(bedroomsInput, 'Number of bedrooms', 1);
        validatePositive(bathroomsInput, 'Number of bathrooms', 1);

        form.addEventListener('submit', function(e){
            let hasError = false;

            if (rentAmountInput) {
                const value = parseFloat(rentAmountInput.value);
                if (isNaN(value) || value < 0) {
                    e.preventDefault();
                    rentAmountInput.setCustomValidity('Rent amount cannot be negative.');
                    rentAmountInput.reportValidity();
                    hasError = true;
                }
            }

            if (bedroomsInput) {
                const value = parseInt(bedroomsInput.value);
                if (isNaN(value) || value < 1) {
                    e.preventDefault();
                    bedroomsInput.setCustomValidity('Number of bedrooms must be at least 1.');
                    bedroomsInput.reportValidity();
                    hasError = true;
                }
            }

            if (bathroomsInput) {
                const value = parseInt(bathroomsInput.value);
                if (isNaN(value) || value < 1) {
                    e.preventDefault();
                    bathroomsInput.setCustomValidity('Number of bathrooms must be at least 1.');
                    bathroomsInput.reportValidity();
                    hasError = true;
                }
            }

            if (hasError) {
                return;
            }
        });
    })();
    </script>
{% endblock %}