{% extends 'dashboard/base.html.twig' %}

{% block title %}{{ tenant.fullName }} - Tenant Details{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <style>
        .tenant-show-container {
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: #333;
            margin: 0;
        }

        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-block;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background: #5568d3;
            transform: translateY(-2px);
        }

        .btn-warning {
            background: #f59e0b;
            color: white;
        }

        .btn-warning:hover {
            background: #d97706;
            transform: translateY(-2px);
        }

        .btn-danger {
            background: #ef4444;
            color: white;
        }

        .btn-danger:hover {
            background: #dc2626;
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: #e0e0e0;
            color: #333;
        }

        .btn-secondary:hover {
            background: #d0d0d0;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .tenant-details {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

        .tenant-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #f0f0f0;
        }

        .tenant-title-section {
            flex: 1;
        }

        .tenant-name {
            font-size: 28px;
            font-weight: 700;
            color: #333;
            margin: 0 0 5px 0;
        }

        .tenant-id {
            color: #999;
            font-size: 14px;
        }

        .status-badge {
            display: inline-block;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-active {
            background: #d1fae5;
            color: #065f46;
        }

        .status-inactive {
            background: #f3f4f6;
            color: #374151;
        }

        .status-moved_out {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .apartment-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 30px;
        }

        .apartment-label {
            font-size: 12px;
            opacity: 0.9;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .apartment-name {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .apartment-address {
            font-size: 14px;
            opacity: 0.95;
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .detail-card {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid #667eea;
        }

        .detail-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .detail-value {
            font-size: 16px;
            font-weight: 600;
            color: #333;
        }

        .actions {
            display: flex;
            gap: 10px;
            justify-content: flex-start;
            margin-top: 30px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            color: #333;
            margin-bottom: 20px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 2px solid #f0f0f0;
        }

        .payments-section,
        .leases-section {
            margin-top: 30px;
        }

        .list-item {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        @media (max-width: 768px) {
            .page-header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .tenant-header {
                flex-direction: column;
            }

            .header-actions {
                width: 100%;
            }

            .header-actions .btn {
                width: 100%;
                text-align: center;
            }

            .details-grid {
                grid-template-columns: 1fr;
            }

            .actions {
                flex-direction: column;
            }

            .actions .btn {
                width: 100%;
                text-align: center;
            }
        }
    </style>
{% endblock %}

{% block header_title %}Tenant Details{% endblock %}

{% block dashboard_content %}
<div class="tenant-show-container">
    <div class="page-header">
        <div class="page-title">👤 {{ tenant.fullName }}</div>
        <div class="header-actions">
            <a href="{{ path('app_tenant_edit', {'id': tenant.id}) }}" class="btn btn-warning">Edit</a>
            <a href="{{ path('app_tenant_index') }}" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="tenant-details">
        <div class="tenant-header">
            <div class="tenant-title-section">
                <h2 class="tenant-name">{{ tenant.fullName }}</h2>
                <div class="tenant-id">Tenant ID: #{{ tenant.id }}</div>
            </div>
            <span class="status-badge status-{{ tenant.status|lower }}">{{ tenant.status|title }}</span>
        </div>

        {% if tenant.getCurrentApartment() %}
            <div class="apartment-section">
                <div class="apartment-label">Currently Renting</div>
                <div class="apartment-name">🏠 {{ tenant.getCurrentApartment().name }}</div>
                <div class="apartment-address">📍 {{ tenant.getCurrentApartment().address }}</div>
            </div>
        {% endif %}

        <div class="details-grid">
            <div class="detail-card">
                <div class="detail-label">Email Address</div>
                <div class="detail-value">{{ tenant.email }}</div>
            </div>
            <div class="detail-card">
                <div class="detail-label">Phone Number</div>
                <div class="detail-value">{{ tenant.phone }}</div>
            </div>
            <div class="detail-card">
                <div class="detail-label">Move-in Date</div>
                <div class="detail-value">{{ tenant.moveInDate|date('M d, Y') }}</div>
            </div>
            {% if tenant.moveOutDate %}
                <div class="detail-card">
                    <div class="detail-label">Move-out Date</div>
                    <div class="detail-value">{{ tenant.moveOutDate|date('M d, Y') }}</div>
                </div>
            {% endif %}
            {% if tenant.dateOfBirth %}
                <div class="detail-card">
                    <div class="detail-label">Date of Birth</div>
                    <div class="detail-value">{{ tenant.dateOfBirth|date('M d, Y') }}</div>
                </div>
            {% endif %}
            {% if tenant.emergencyContact %}
                <div class="detail-card">
                    <div class="detail-label">Emergency Contact</div>
                    <div class="detail-value">{{ tenant.emergencyContact }}</div>
                </div>
            {% endif %}
            {% if tenant.address %}
                <div class="detail-card">
                    <div class="detail-label">Address</div>
                    <div class="detail-value">{{ tenant.address }}</div>
                </div>
            {% endif %}
        </div>

        <div class="section-title">📋 Payments</div>
        <div class="payments-section">
            {% if tenant.getPayments()|length > 0 %}
                {% for payment in tenant.getPayments() %}
                    <div class="list-item">
                        <div>
                            <strong>Payment #{{ payment.id }}</strong><br>
                            <small style="color: #999;">{{ payment.paymentDate|date('M d, Y') }}</small>
                        </div>
                        <div>
                            <strong>{{ payment.amount|peso }}</strong>
                            <span class="status-badge status-{{ payment.status|lower }}" style="margin-left: 10px;">{{ payment.status|title }}</span>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p style="color: #999; text-align: center; padding: 20px;">No payments recorded.</p>
            {% endif %}
        </div>

        <div class="section-title">📄 Leases</div>
        <div class="leases-section">
            {% if tenant.getLeases()|length > 0 %}
                {% for lease in tenant.getLeases() %}
                    <div class="list-item">
                        <div>
                            <strong>Lease #{{ lease.id }}</strong><br>
                            <small style="color: #999;">{{ lease.startDate|date('M d, Y') }} - {{ lease.endDate|date('M d, Y') }}</small>
                        </div>
                        <div>
                            <span class="status-badge" style="background: {{ lease.isActive() ? '#d1fae5' : '#f3f4f6' }}; color: {{ lease.isActive() ? '#065f46' : '#374151' }};">
                                {{ lease.isActive() ? 'Active' : 'Inactive' }}
                            </span>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p style="color: #999; text-align: center; padding: 20px;">No leases found.</p>
            {% endif %}
        </div>

        <div class="actions">
            <a href="{{ path('app_tenant_edit', {'id': tenant.id}) }}" class="btn btn-warning">Edit Tenant</a>
            <form method="post" action="{{ path('app_tenant_delete', {'id': tenant.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this tenant?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tenant.id) }}">
                <button type="submit" class="btn btn-danger">Delete Tenant</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
