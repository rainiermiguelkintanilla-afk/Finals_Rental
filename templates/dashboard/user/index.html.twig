{% extends 'dashboard/base.html.twig' %}

{% block title %}Users - Rental Management{% endblock %}

{% block header_title %}Users Management{% endblock %}

{% block dashboard_content %}
<div class="container" style="padding: 20px;">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 class="page-title">Users</h1>
        <a href="{{ path('app_user_new') }}" class="btn btn-primary" style="padding: 10px 20px; background: #20b2aa; color: white; text-decoration: none; border-radius: 8px; transition: background 0.3s;">+ Add New User</a>
    </div>

    {% if users is empty %}
        <div class="empty-state" style="text-align: center; padding: 40px;">
            <h3>No users found</h3>
            <p>Start by adding your first user.</p>
            <a href="{{ path('app_user_new') }}" class="btn btn-primary" style="padding: 10px 20px; background: #20b2aa; color: white; text-decoration: none; border-radius: 8px; display: inline-block; margin-top: 10px;">Add First User</a>
        </div>
    {% else %}
        <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);">
            <thead>
                <tr style="background: #f8f9fa;">
                    <th style="padding: 15px; text-align: left; border-bottom: 2px solid #dee2e6;">ID</th>
                    <th style="padding: 15px; text-align: left; border-bottom: 2px solid #dee2e6;">Email</th>
                    <th style="padding: 15px; text-align: left; border-bottom: 2px solid #dee2e6;">Roles</th>
                    <th style="padding: 15px; text-align: left; border-bottom: 2px solid #dee2e6;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr style="border-bottom: 1px solid #dee2e6;">
                    <td style="padding: 15px;">{{ user.id }}</td>
                    <td style="padding: 15px;">{{ user.email }}</td>
                    <td style="padding: 15px;">
                        {% for role in user.roles %}
                            <span style="padding: 5px 10px; background: {{ role == 'ROLE_ADMIN' ? '#dc3545' : '#20b2aa' }}; color: white; border-radius: 4px; font-size: 12px; margin-right: 5px;">
                                {{ role == 'ROLE_ADMIN' ? 'Admin' : (role == 'ROLE_STAFF' ? 'Staff' : 'User') }}
                            </span>
                        {% endfor %}
                    </td>
                    <td style="padding: 15px;">
                        <a href="{{ path('app_user_show', {'id': user.id}) }}" style="padding: 5px 10px; background: #17a2b8; color: white; text-decoration: none; border-radius: 4px; margin-right: 5px; transition: background 0.3s;">View</a>
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" style="padding: 5px 10px; background: #ffc107; color: #000; text-decoration: none; border-radius: 4px; margin-right: 5px; transition: background 0.3s;">Edit</a>
                        <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                            <button type="submit" style="padding: 5px 10px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; transition: background 0.3s;">Delete</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

<style>
    .btn-primary:hover {
        background: #1a9b8f !important;
    }
    
    .container {
        max-width: 100%;
    }
    
    .page-title {
        font-size: 24px;
        font-weight: 600;
        color: #333;
        margin: 0;
    }
    
    table tbody tr:hover {
        background-color: #f8f9fa;
    }
    
    table a:hover {
        opacity: 0.8;
    }
    
    table button:hover {
        opacity: 0.8;
    }
</style>
{% endblock %}
