{% extends 'dashboard/base.html.twig' %}

{% block title %}User Details - Rental Management{% endblock %}

{% block header_title %}User Details{% endblock %}

{% block dashboard_content %}
<div class="container" style="padding: 20px; max-width: 800px;">
    <div style="background: white; padding: 30px; border-radius: 8px;">
        <div style="margin-bottom: 20px;">
            <strong>ID:</strong> {{ user.id }}
        </div>
        <div style="margin-bottom: 20px;">
            <strong>Email:</strong> {{ user.email }}
        </div>
        <div style="margin-bottom: 20px;">
            <strong>Roles:</strong>
            {% for role in user.roles %}
                <span style="padding: 5px 10px; background: {{ role == 'ROLE_ADMIN' ? '#dc3545' : '#20b2aa' }}; color: white; border-radius: 4px; font-size: 12px; margin-left: 5px;">
                    {{ role == 'ROLE_ADMIN' ? 'Admin' : (role == 'ROLE_STAFF' ? 'Staff' : 'User') }}
                </span>
            {% endfor %}
        </div>
        <div style="margin-top: 30px;">
            <a href="{{ path('app_user_edit', {'id': user.id}) }}" style="padding: 10px 20px; background: #ffc107; color: #000; text-decoration: none; border-radius: 4px; margin-right: 10px;">Edit</a>
            <a href="{{ path('app_user_change_password', {'id': user.id}) }}" style="padding: 10px 20px; background: #17a2b8; color: white; text-decoration: none; border-radius: 4px; margin-right: 10px;">Change Password</a>
            <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline; margin-right: 10px;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                <button type="submit" style="padding: 10px 20px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">Delete</button>
            </form>

            {# Show force-delete option if user has activity logs #}
            {% if activityLogCount is defined and activityLogCount > 0 %}
                <form method="post" action="{{ path('app_user_force_delete', {'id': user.id}) }}" style="display: inline; margin-right: 10px;" onsubmit="return confirm('This will permanently delete the user and ALL their activity logs. Continue?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('force_delete' ~ user.id) }}">
                    <button type="submit" style="padding: 10px 20px; background: #8b0000; color: white; border: none; border-radius: 4px; cursor: pointer;">Force Delete (remove logs)</button>
                </form>
            {% endif %}

            <a href="{{ path('app_user_index') }}" style="padding: 10px 20px; background: #6c757d; color: white; text-decoration: none; border-radius: 4px;">Back to List</a>
        </div>
        {% if activityLogCount is defined %}
            <div style="margin-top: 15px; color: #666;">
                Activity logs: <strong>{{ activityLogCount }}</strong>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}






