{% extends 'dashboard/base.html.twig' %}

{% block title %}Lease Details - Rental Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-colors.css') }}">
    <style>
        .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
        .page-header { 
            display:flex; 
            justify-content: space-between; 
            align-items:center; 
            margin-bottom: 20px; 
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        .page-title { font-size: 2rem; color: #0ea5e9; }
        .card { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
        .label { color: #64748b; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; }
        .value { color: #0f172a; font-weight: 600; }
        .btn { padding: 10px 16px; border-radius: 6px; text-decoration: none; font-weight: 600; }
        .btn-primary { background: #0ea5e9; color: #fff; }
        .btn-warning { background: #f59e0b; color: #fff; }
        .btn-danger { background: #ef4444; color: #fff; border: none; }
    </style>
{% endblock %}

{% block header_title %}Lease Details{% endblock %}

{% block dashboard_content %}
<div class="container">
    <div class="page-header">
        <h1 class="page-title">Lease #{{ lease.id }}</h1>
        <div style="display:flex; gap:8px;">
            <a href="{{ path('app_lease_edit', {id: lease.id}) }}" class="btn btn-warning">Edit</a>
            <a href="{{ path('app_lease_index') }}" class="btn btn-primary">Back</a>
        </div>
    </div>

    <div class="card">
        <div class="grid">
            <div>
                <div class="label">Tenant</div>
                <div class="value">{{ lease.tenant.fullName }}</div>
            </div>
            <div>
                <div class="label">Apartment</div>
                <div class="value">{{ lease.apartment.name }}</div>
            </div>
            <div>
                <div class="label">Start Date</div>
                <div class="value">{{ lease.startDate|date('Y-m-d') }}</div>
            </div>
            <div>
                <div class="label">End Date</div>
                <div class="value">{{ lease.endDate|date('Y-m-d') }}</div>
            </div>
            <div>
                <div class="label">Monthly Rent</div>
                <div class="value">{{ lease.monthlyRent|peso }}</div>
            </div>
            <div>
                <div class="label">Status</div>
                <div class="value">{{ lease.status|title }}</div>
            </div>
            <div>
                <div class="label">Duration</div>
                <div class="value">{{ lease.getDurationInMonths() }} months</div>
            </div>
        </div>

        {% if lease.notes %}
            <div style="margin-top:16px;">
                <div class="label">Notes</div>
                <div class="value">{{ lease.notes }}</div>
            </div>
        {% endif %}

        <div style="margin-top: 16px;">
            <form method="post" action="{{ path('app_lease_delete', {id: lease.id}) }}" onsubmit="return confirm('Delete this lease?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lease.id) }}">
                <button class="btn btn-danger" type="submit">Delete</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}





