{% extends 'dashboard/base.html.twig' %}

{% block title %}Edit Lease - Rental Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-colors.css') }}">
    <style>
        .container { max-width: 800px; margin: 0 auto; padding: 20px; }
        .page-title { font-size: 2rem; color: #0ea5e9; margin-bottom: 20px; }
        .card { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .form-group { margin-bottom: 16px; }
        .form-actions { display: flex; gap: 10px; justify-content: flex-end; }
        .btn { padding: 10px 16px; border-radius: 6px; text-decoration: none; font-weight: 600; border: none; }
        .btn-primary { background: #0ea5e9; color: #fff; }
        .btn-secondary { background: #64748b; color: #fff; }
    </style>
{% endblock %}

{% block header_title %}Edit Lease{% endblock %}

{% block dashboard_content %}
<div class="container">
    <h1 class="page-title">Edit Lease #{{ lease.id }}</h1>
    <div class="card">
        {{ form_start(form) }}
            <div class="form-group">{{ form_row(form.tenant) }}</div>
            <div class="form-group">{{ form_row(form.apartment) }}</div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div class="form-group">{{ form_row(form.startDate) }}</div>
                <div class="form-group">{{ form_row(form.endDate) }}</div>
            </div>
            <div class="form-group">{{ form_row(form.monthlyRent) }}</div>
            <div class="form-group">{{ form_row(form.status) }}</div>
            <div class="form-group">{{ form_row(form.notes) }}</div>
            <div class="form-actions">
                <a href="{{ path('app_lease_show', {id: lease.id}) }}" class="btn btn-secondary">Cancel</a>
                {{ form_widget(form.save) }}
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}





