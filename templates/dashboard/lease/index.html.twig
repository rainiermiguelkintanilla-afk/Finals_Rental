{% extends 'dashboard/base.html.twig' %}

{% block title %}Leases - Rental Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-colors.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-lease.css') }}">
{% endblock %}

{% block header_title %}Leases{% endblock %}

{% block dashboard_content %}
<div class="container">
    <div class="page-header">
        <h1 class="page-title">Leases</h1>
        <a href="{{ path('app_lease_new') }}" class="btn btn-primary">+ New Lease</a>
    </div>

    {% if leases is empty %}
        <div class="empty-state">
            No leases found. <a href="{{ path('app_lease_new') }}">Create the first lease</a>.
        </div>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tenant</th>
                    <th>Apartment</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Rent</th>
                    <th>Status</th>
                    <th style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for lease in leases %}
                    <tr>
                        <td>{{ lease.id }}</td>
                        <td>{{ lease.tenant.fullName }}</td>
                        <td>{{ lease.apartment.name }}</td>
                        <td>{{ lease.startDate|date('Y-m-d') }}</td>
                        <td>{{ lease.endDate|date('Y-m-d') }}</td>
                        <td>{{ lease.monthlyRent|peso }}</td>
                        <td>
                            <span class="status status-{{ lease.status }}">{{ lease.status|title }}</span>
                        </td>
                        <td>
                            <div class="actions">
                                <a class="btn btn-sm btn-primary" href="{{ path('app_lease_show', {id: lease.id}) }}">View</a>
                                <a class="btn btn-sm btn-warning" href="{{ path('app_lease_edit', {id: lease.id}) }}">Edit</a>
                                <form method="post" action="{{ path('app_lease_delete', {id: lease.id}) }}" onsubmit="return confirm('Delete this lease?');" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lease.id) }}">
                                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}





