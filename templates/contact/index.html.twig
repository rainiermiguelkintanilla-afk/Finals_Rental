{% extends 'base.html.twig' %}

{% block title %}Contact Us - Rainier's Real Estate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .public-logo-image {
            height: 40px;
            max-height: 40px;
            width: auto;
            max-width: min(220px, 52vw);
            object-fit: contain;
            object-position: left center;
            background: white;
            padding: 6px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            border: 2px solid #20b2aa;
            display: block;
            box-sizing: content-box;
        }

        .nav-links {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .nav-link {
            color: white;
            text-decoration: none;
            font-weight: 600;
            padding: 10px 14px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: transform 0.2s ease, background-color 0.2s ease;
            font-size: 14px;
        }

        .nav-link:hover {
            transform: translateY(-1px);
            background: rgba(32, 178, 170, 0.15);
        }

        .login-btn {
            background: white;
            color: #0a1a2e;
            padding: 10px 20px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 700;
            border: 2px solid #20b2aa;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .login-btn:hover {
            background: #20b2aa;
            color: white;
        }

        .page {
            min-height: 100vh;
            background: linear-gradient(135deg, #1a4b5c, #2d6a7a);
            padding-top: 90px;
            color: white;
            overflow-x: hidden;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .hero {
            padding: 60px 0 20px;
        }

        .hero-title {
            font-size: 44px;
            font-weight: 800;
            margin-bottom: 14px;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.35);
        }

        .hero-subtitle {
            font-size: 18px;
            opacity: 0.95;
            line-height: 1.7;
            max-width: 820px;
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 18px;
            padding: 30px;
            backdrop-filter: blur(10px);
            margin-bottom: 50px;
        }

        .card.card--embed-only {
            padding: 0;
        }

        .google-form-embed {
            position: relative;
            width: 100%;
            min-height: 920px;
            border-radius: 12px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.95);
        }

        .card--embed-only .google-form-embed {
            border-radius: 0;
        }

        .google-form-embed iframe {
            display: block;
            width: 100%;
            min-width: 100%;
            max-width: 100%;
            min-height: 920px;
            height: 920px;
            border: 0;
            color-scheme: light;
        }

        .google-form-placeholder {
            padding: 1.5rem;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.95);
            color: #1a2a3a;
            font-size: 15px;
            line-height: 1.6;
        }

        .google-form-placeholder code {
            font-size: 13px;
            word-break: break-all;
            display: block;
            margin-top: 6px;
            padding: 8px 10px;
            background: #f1f5f9;
            border-radius: 8px;
        }

        .flash {
            margin-bottom: 18px;
            padding: 14px 16px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.25);
        }

        .flash.success { background: rgba(74, 222, 128, 0.12); }
        .flash.error { background: rgba(248, 113, 113, 0.12); }

        @media (max-width: 700px) {
            .nav-links { display: none; }
            .hero-title { font-size: 32px; }
            .hero-subtitle { font-size: 16px; }
            .card:not(.card--embed-only) { padding: 20px; }
            .google-form-embed,
            .google-form-embed iframe {
                min-height: 1100px;
            }
            .google-form-embed iframe {
                height: 1100px;
            }
        }
    </style>
{% endblock %}

{% block body %}
<main class="page">
    <div class="container hero">
        <h1 class="hero-title">Contact Us</h1>
        <p class="hero-subtitle">
            Have a question about rentals or property management? Use the form below to reach us — responses are collected securely through Google Forms.
        </p>
    </div>

    <div class="container container--form-wide">
        <section class="card{% if googleFormEmbedUrl|trim is not empty %} card--embed-only{% endif %}" aria-label="Contact form">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label == 'success' ? 'success' : 'error' }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% if googleFormEmbedUrl|trim is not empty %}
                <div class="google-form-embed">
                    <iframe
                        title="Contact Rainier&apos;s Real Estate"
                        src="{{ googleFormEmbedUrl }}"
                        width="100%"
                        height="920"
                        loading="lazy"
                        allow="fullscreen"
                    >Loading…</iframe>
                </div>
            {% else %}
                <div class="google-form-placeholder">
                    <strong>Google Form URL not set yet.</strong>
                    In Google Forms, open your form → <strong>Send</strong> → <strong>&lt;&gt;</strong> (embed) → copy the
                    <code>src</code> from the iframe (it should look like
                    <code>https://docs.google.com/forms/d/e/…/viewform?embedded=true</code>).
                    Then set <code>CONTACT_GOOGLE_FORM_EMBED_URL</code> in your <code>.env</code> file to that value and refresh this page.
                </div>
            {% endif %}
        </section>
    </div>
</main>
{% endblock %}

