{% extends 'base.html.twig' %}

{% block title %}About Us - Rainier's Real Estate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Navbar logo: base uses .public-logo-image — keep rules aligned with landing page */
        .public-logo-image {
            height: 40px;
            max-height: 40px;
            width: auto;
            max-width: min(220px, 52vw);
            object-fit: contain;
            object-position: left center;
            background: white;
            padding: 6px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            border: 2px solid #20b2aa;
            display: block;
            box-sizing: content-box;
        }

        .login-btn,
        .about-btn,
        .home-btn {
            background: white;
            color: #0a1a2e;
            padding: 10px 20px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            border: 2px solid #20b2aa;
            transition: all 0.3s ease;
            font-size: 15px;
            white-space: nowrap;
        }

        .login-btn:hover,
        .about-btn:hover,
        .home-btn:hover {
            background: #20b2aa;
            color: white;
        }

        .page {
            min-height: 100vh;
            background: linear-gradient(135deg, #1a4b5c, #2d6a7a);
            padding-top: 90px; /* header offset */
            color: white;
            overflow-x: hidden;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .hero {
            padding: 60px 0 30px;
        }

        .hero-title {
            font-size: 44px;
            font-weight: 800;
            margin-bottom: 14px;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.35);
        }

        .hero-subtitle {
            font-size: 18px;
            opacity: 0.95;
            line-height: 1.7;
            max-width: 820px;
        }

        /* Story + feature cards (moved from landing page) */
        .about-story-section {
            padding: 0 0 50px;
        }

        .about-story-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .about-story-text {
            font-size: 18px;
            line-height: 1.8;
            opacity: 0.95;
            margin-bottom: 18px;
            max-width: 900px;
        }

        .about-story-features {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-top: 36px;
        }

        .feature-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 10px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.12);
        }

        .feature-icon {
            font-size: 32px;
            margin-bottom: 10px;
        }

        .feature-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .feature-desc {
            font-size: 14px;
            opacity: 0.9;
        }

        @media (max-width: 768px) {
            .about-story-features { grid-template-columns: 1fr; }
        }

        .content {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 18px;
            padding: 40px;
            margin-bottom: 50px;
            backdrop-filter: blur(10px);
        }

        .section-title {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .section-text {
            font-size: 16px;
            opacity: 0.95;
            line-height: 1.8;
            margin-bottom: 22px;
        }

        /* Meet the Team (match your screenshot: photo card + name/role + socials) */
        .team-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 28px;
        }

        @media (max-width: 1100px) {
            .team-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (max-width: 600px) {
            .team-grid { grid-template-columns: 1fr; }
        }

        .team-card {
            background: rgba(255, 255, 255, 0.92);
            color: #1a2a3a;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
            border: 1px solid rgba(26, 75, 92, 0.08);
            min-width: 0;
        }

        .team-card__photo {
            width: 100%;
            height: 240px;
            object-fit: cover;
            object-position: center;
            display: block;
            background: linear-gradient(135deg, rgba(32, 178, 170, 0.25), rgba(10, 26, 46, 0.15));
        }

        /* Portrait crop tuned for Manager.jpeg — bias toward upper body/face (object-fit: cover) */
        .team-card__photo--director {
            object-position: 50% 12%;
        }

        /* Portrait crops: align focal point (face) toward visual center of the 240px-tall frame */
        .team-card__photo--lea {
            object-position: 50% 5%;
        }

        /* Slight horizontal nudge helps when the subject sits off-center in the source frame */
        .team-card__photo--rhea {
            object-position: 48% 5%;
        }

        .team-card__photo--yasin {
            object-position: 50% 10%;
        }

        .team-card__body {
            padding: 18px 18px 16px;
            text-align: center;
        }

        .team-socials {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .team-social {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: #1a2a3a;
            background: rgba(26, 75, 92, 0.06);
            border: 1px solid rgba(26, 75, 92, 0.12);
            transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
            font-weight: 900;
            line-height: 1;
        }

        .team-social:hover {
            transform: translateY(-2px);
            background: rgba(32, 178, 170, 0.14);
            border-color: rgba(32, 178, 170, 0.35);
        }

        .team-name {
            font-size: 15px;
            font-weight: 800;
            margin: 0 0 6px;
            word-wrap: break-word;
        }

        .team-position {
            font-size: 12px;
            opacity: 0.75;
            margin: 0 0 14px;
            line-height: 1.5;
            word-wrap: break-word;
        }

        @media (max-width: 900px) {
            .content { padding: 28px; }
        }

        @media (max-width: 600px) {
            .public-header-container { gap: 10px; }
            .hero-title { font-size: 32px; }
            .hero-subtitle { font-size: 16px; }
            .content { padding: 22px; }
        }

        /* Sections moved from landing page */
        .section-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .section-title-lg {
            font-size: 42px;
            color: #1a4b5c;
            margin-bottom: 15px;
            font-weight: bold;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.25);
        }

        .section-subtitle {
            font-size: 18px;
            opacity: 0.9;
        }

        .units-section,
        .news-section {
            background: white;
            color: #333;
            padding: 80px 0;
        }

        .units-container,
        .news-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .units-grid,
        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }

        .unit-card,
        .news-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .unit-card:hover,
        .news-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .unit-image,
        .news-image {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

        .news-image { height: 200px; }

        .unit-content,
        .news-content {
            padding: 20px;
        }

        .unit-name {
            font-size: 22px;
            font-weight: bold;
            color: #1a4b5c;
            margin-bottom: 10px;
        }

        .unit-address {
            color: #666;
            font-size: 14px;
            margin-bottom: 15px;
        }

        .unit-details {
            display: flex;
            gap: 20px;
            margin-bottom: 15px;
            font-size: 14px;
            color: #666;
        }

        .unit-price {
            font-size: 24px;
            font-weight: bold;
            color: #20b2aa;
            margin-bottom: 15px;
        }

        .unit-status {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-available { background: #d4edda; color: #155724; }
        .status-occupied { background: #fff3cd; color: #856404; }

        .feedbacks-section,
        .contacts-section {
            background: linear-gradient(135deg, #0a1a2e, #16213e);
            color: white;
            padding: 80px 0;
        }

        .contacts-section {
            background: linear-gradient(135deg, #1a4b5c, #2d6a7a);
        }

        .feedbacks-container,
        .contacts-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .feedbacks-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }

        .feedback-card {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .feedback-rating { color: #ffd700; font-size: 18px; }
        .feedback-text { font-size: 16px; line-height: 1.8; margin-bottom: 20px; font-style: italic; }

        .feedback-author { display: flex; align-items: center; gap: 15px; }
        .feedback-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #20b2aa;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
        }

        .feedback-author-name { font-weight: 600; margin-bottom: 5px; }
        .feedback-author-role { font-size: 14px; opacity: 0.8; }

        .news-date { color: #20b2aa; font-size: 14px; font-weight: 600; margin-bottom: 10px; }
        .news-title { font-size: 20px; font-weight: bold; color: #1a4b5c; margin-bottom: 10px; }
        .news-excerpt { color: #666; font-size: 14px; line-height: 1.6; }

        .contacts-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            margin-top: 50px;
        }

        .contact-info { display: flex; flex-direction: column; gap: 30px; }
        .contact-item { display: flex; align-items: start; gap: 20px; }

        .contact-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }

        .contact-details h3 { font-size: 20px; margin-bottom: 8px; }
        .contact-details p { font-size: 16px; opacity: 0.9; line-height: 1.6; }

        .contact-form {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
        }

        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 600; }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 16px;
            font-family: inherit;
        }

        .form-group input::placeholder,
        .form-group textarea::placeholder { color: rgba(255, 255, 255, 0.6); }

        .form-group textarea { resize: vertical; min-height: 120px; }

        .submit-btn {
            background: #20b2aa;
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .submit-btn:hover { background: #008b8b; transform: translateY(-2px); }

        @media (max-width: 900px) {
            .contacts-content { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .section-title-lg { font-size: 32px; }
            .units-grid,
            .feedbacks-grid,
            .news-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
<main class="page">
    <div class="container hero">
        <h1 class="hero-title">About Rainier&apos;s Real Estate</h1>
        <p class="hero-subtitle">
            We&apos;re a dedicated property management team focused on transparent service, secure transactions,
            and a smooth rental experience for both tenants and owners.
        </p>
    </div>

    <section class="about-story-section" aria-label="About our company">
        <div class="about-story-inner">
            <p class="about-story-text">
                Welcome to Rainier&apos;s Real Estate, your trusted partner in finding the perfect rental property.
                With years of experience in the real estate industry, we specialize in providing exceptional
                rental management services and helping tenants find their ideal homes.
            </p>
            <p class="about-story-text">
                Our mission is to make the rental process seamless and stress-free for both property owners
                and tenants. We offer a wide range of properties, from cozy apartments to spacious family homes,
                all carefully selected to meet the highest standards of quality and comfort.
            </p>
            <div class="about-story-features">
                <div class="feature-box">
                    <div class="feature-icon" aria-hidden="true">🏠</div>
                    <div class="feature-title">Quality Properties</div>
                    <div class="feature-desc">Carefully selected and maintained properties</div>
                </div>
                <div class="feature-box">
                    <div class="feature-icon" aria-hidden="true">💼</div>
                    <div class="feature-title">Professional Service</div>
                    <div class="feature-desc">Experienced team dedicated to your satisfaction</div>
                </div>
                <div class="feature-box">
                    <div class="feature-icon" aria-hidden="true">🔒</div>
                    <div class="feature-title">Secure &amp; Safe</div>
                    <div class="feature-desc">Your security and privacy are our top priorities</div>
                </div>
                <div class="feature-box">
                    <div class="feature-icon" aria-hidden="true">⚡</div>
                    <div class="feature-title">Quick Response</div>
                    <div class="feature-desc">Fast and efficient service when you need it</div>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Team: placeholder names & roles — edit in templates/about/index.html.twig -->
        <section class="content" aria-label="Meet the Team">
            <h2 class="section-title">Meet the Team</h2>
            <p class="section-text">
                Leadership and support are built around responsiveness and clarity—so every step of your rental journey
                feels simple. Names and titles below are sample placeholders you can swap for your real team.
            </p>

            <div class="team-grid">
                <div class="team-card">
                    <img class="team-card__photo team-card__photo--director" src="{{ asset('img/Manager.jpeg') }}" alt="Rainier Miguel Kintanilla" loading="lazy" width="600" height="800" />
                    <div class="team-card__body">
                        <div class="team-name">Rainier Miguel Kintanilla</div>
                        <div class="team-position">Managing Director</div>
                        <div class="team-socials" aria-label="Social links">
                            <a class="team-social" href="#" aria-label="Facebook">f</a>
                            <a class="team-social" href="#" aria-label="X">x</a>
                            <a class="team-social" href="#" aria-label="Instagram">ig</a>
                        </div>
                    </div>
                </div>
                <div class="team-card">
                    <img class="team-card__photo team-card__photo--lea" src="{{ asset('img/Lease.jpg') }}" alt="Lea Paras" loading="lazy" width="600" height="800" />
                    <div class="team-card__body">
                        <div class="team-name">Lea Paras</div>
                        <div class="team-position">Leasing Consultant</div>
                        <div class="team-socials" aria-label="Social links">
                            <a class="team-social" href="#" aria-label="Facebook">f</a>
                            <a class="team-social" href="#" aria-label="X">x</a>
                            <a class="team-social" href="#" aria-label="Instagram">ig</a>
                        </div>
                    </div>
                </div>
                <div class="team-card">
                    <img class="team-card__photo team-card__photo--rhea" src="{{ asset('img/Community.jpg') }}" alt="Rhea Alonzo" loading="lazy" width="600" height="800" />
                    <div class="team-card__body">
                        <div class="team-name">Rhea Alonzo</div>
                        <div class="team-position">Community Coordinator</div>
                        <div class="team-socials" aria-label="Social links">
                            <a class="team-social" href="#" aria-label="Facebook">f</a>
                            <a class="team-social" href="#" aria-label="X">x</a>
                            <a class="team-social" href="#" aria-label="Instagram">ig</a>
                        </div>
                    </div>
                </div>
                <div class="team-card">
                    <img class="team-card__photo team-card__photo--yasin" src="{{ asset('img/Maintainance.jpg') }}" alt="Yasin Lim" loading="lazy" width="600" height="800" />
                    <div class="team-card__body">
                        <div class="team-name">Yasin Lim</div>
                        <div class="team-position">Maintenance Supervisor</div>
                        <div class="team-socials" aria-label="Social links">
                            <a class="team-social" href="#" aria-label="Facebook">f</a>
                            <a class="team-social" href="#" aria-label="X">x</a>
                            <a class="team-social" href="#" aria-label="Instagram">ig</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Units Section (moved from landing page) -->
    <section class="units-section" aria-label="Available Units">
        <div class="units-container">
            <div class="section-header">
                <h2 class="section-title-lg">Available Units</h2>
                <p class="section-subtitle">Discover our premium rental properties</p>
            </div>

            <div class="units-grid">
                {% if apartments is defined and apartments|length > 0 %}
                    {% for apartment in apartments %}
                        {% set imageFiles = ['apt3.jpg', 'apt4.jpg', 'apt5.jpg', 'apt6.jpg', 'apt7.jpg', 'apt8.jpg'] %}
                        {% set imageIndex = (apartment.id - 1) % imageFiles|length %}
                        {% set imageFile = imageFiles[imageIndex] %}
                        <div class="unit-card">
                            <img src="{{ asset('img/' ~ imageFile) }}" alt="{{ apartment.name }}" class="unit-image">
                            <div class="unit-content">
                                <h3 class="unit-name">{{ apartment.name }}</h3>
                                <p class="unit-address">{{ apartment.address }}</p>
                                <div class="unit-details">
                                    <span>🛏️ {{ apartment.bedrooms }} Bedrooms</span>
                                    <span>🚿 {{ apartment.bathrooms }} Bathrooms</span>
                                </div>
                                <div class="unit-price">{{ apartment.rentAmount|peso }}/month</div>
                                <span class="unit-status status-{{ apartment.status|lower }}">{{ apartment.status }}</span>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #666;">
                        <p style="font-size: 18px;">No available units at the moment. Check back soon!</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    <!-- Feedbacks Section (moved from landing page) -->
    <section class="feedbacks-section" aria-label="What Our Clients Say">
        <div class="feedbacks-container">
            <div class="section-header">
                <h2 class="section-title-lg">What Our Clients Say</h2>
                <p class="section-subtitle">Real feedback from satisfied tenants</p>
            </div>

            <div class="feedbacks-grid">
                <div class="feedback-card">
                    <div class="feedback-rating">★★★★★</div>
                    <p class="feedback-text">
                        "Rainier's Real Estate made finding my perfect apartment so easy! The team was professional,
                        responsive, and helped me find exactly what I was looking for. Highly recommended!"
                    </p>
                    <div class="feedback-author">
                        <div class="feedback-avatar">SM</div>
                        <div class="feedback-author-info">
                            <div class="feedback-author-name">Sarah Martinez</div>
                            <div class="feedback-author-role">Current Tenant</div>
                        </div>
                    </div>
                </div>
                <div class="feedback-card">
                    <div class="feedback-rating">★★★★★</div>
                    <p class="feedback-text">
                        "Excellent service from start to finish! The property management is top-notch, and any issues
                        are resolved quickly. I've been a happy tenant for over two years now."
                    </p>
                    <div class="feedback-author">
                        <div class="feedback-avatar">JD</div>
                        <div class="feedback-author-info">
                            <div class="feedback-author-name">John Davis</div>
                            <div class="feedback-author-role">Long-term Tenant</div>
                        </div>
                    </div>
                </div>
                <div class="feedback-card">
                    <div class="feedback-rating">★★★★★</div>
                    <p class="feedback-text">
                        "The best rental experience I've ever had! The apartments are well-maintained, the staff is
                        friendly, and the whole process was smooth and stress-free. Thank you!"
                    </p>
                    <div class="feedback-author">
                        <div class="feedback-avatar">EW</div>
                        <div class="feedback-author-info">
                            <div class="feedback-author-name">Emily Wilson</div>
                            <div class="feedback-author-role">New Tenant</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- News Section (moved from landing page) -->
    <section class="news-section" aria-label="Latest News & Updates">
        <div class="news-container">
            <div class="section-header">
                <h2 class="section-title-lg" style="color:#1a4b5c; text-shadow:none;">Latest News &amp; Updates</h2>
                <p class="section-subtitle" style="color:#666;">Stay informed about our properties and services</p>
            </div>

            <div class="news-grid">
                <div class="news-card">
                    <img src="{{ asset('img/apt3.jpg') }}" alt="New Properties Available" class="news-image">
                    <div class="news-content">
                        <div class="news-date">December 15, 2024</div>
                        <h3 class="news-title">New Properties Available This Month</h3>
                        <p class="news-excerpt">
                            We're excited to announce several new premium rental properties now available.
                            These units feature modern amenities and prime locations.
                        </p>
                    </div>
                </div>
                <div class="news-card">
                    <img src="{{ asset('img/apt4.jpg') }}" alt="Holiday Maintenance Schedule" class="news-image">
                    <div class="news-content">
                        <div class="news-date">December 10, 2024</div>
                        <h3 class="news-title">Holiday Maintenance Schedule</h3>
                        <p class="news-excerpt">
                            Our maintenance team will be available throughout the holiday season to ensure
                            all properties remain in excellent condition.
                        </p>
                    </div>
                </div>
                <div class="news-card">
                    <img src="{{ asset('img/apt5.jpg') }}" alt="Tenant Appreciation Month" class="news-image">
                    <div class="news-content">
                        <div class="news-date">December 5, 2024</div>
                        <h3 class="news-title">Tenant Appreciation Month</h3>
                        <p class="news-excerpt">
                            We're celebrating our amazing tenants this month! Thank you for choosing
                            Rainier's Real Estate as your rental partner.
                        </p>
                    </div>
                </div>
            </div>
