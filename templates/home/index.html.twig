{% extends 'base.html.twig' %}

{% block title %}Rainier's Real Estate{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/rentals.css') }}">
    <style>
        @font-face {
            font-family: 'SITKAVF';
            src: url('{{ asset('fonts/SITKAVF-Small.TTF') }}') format('truetype');
            font-weight: normal;
            font-style: normal;
        }

        @font-face {
            font-family: 'SITKAVF';
            src: url('{{ asset('fonts/SITKAVF-SmallBold.TTF') }}') format('truetype');
            font-weight: bold;
            font-style: normal;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'SITKAVF', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a1a2e, #16213e, #1e3a5f);
            color: white;
            overflow-x: hidden;
        }

        /* Navbar logo (same class as base.html.twig public header) */
        .public-logo-image {
            height: 40px;
            max-height: 40px;
            width: auto;
            max-width: min(220px, 52vw);
            object-fit: contain;
            object-position: left center;
            background: white;
            padding: 6px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            border: 2px solid #20b2aa;
            display: block;
            box-sizing: content-box;
        }

        .login-btn,
        .about-btn {
            background: white;
            color: #0a1a2e;
            padding: 10px 20px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            border: 2px solid #20b2aa;
            transition: all 0.3s ease;
            font-size: 15px;
            white-space: nowrap;
        }

        .login-btn:hover,
        .about-btn:hover {
            background: #20b2aa;
            color: white;
        }

        /* Rewards Banner */
        .rewards-banner {
            background: linear-gradient(135deg, #20b2aa, #008b8b);
            padding: 20px 0;
            margin-top: 70px;
        }

        .rewards-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
        }

        .rewards-content {
            display: flex;
            align-items: center;
            gap: 30px;
        }

        .rewards-mascot {
            width: 60px;
            height: 60px;
            background: #ff6b35;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .rewards-text {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .rewards-title {
            font-size: 28px;
            font-weight: bold;
        }

        .rewards-subtitle {
            font-size: 14px;
            opacity: 0.9;
        }

        .rewards-features {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 14px;
        }

        .checkmark {
            color: #4ade80;
            font-weight: bold;
        }

        .learn-more-btn {
            background: #4a9eff;
            color: white;
            padding: 12px 24px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .learn-more-btn:hover {
            background: #3a8eef;
            transform: translateY(-2px);
        }

        /* Hero Section */
        .hero {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            background: linear-gradient(135deg, #1a4b5c, #2d6a7a);
            background-image: url('{{ asset('img/hero-img-1.jpg') }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            overflow: hidden;
            padding-top: 90px; /* account for fixed global navbar */
            box-sizing: border-box;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(26, 75, 92, 0.4);
            z-index: 1;
        }

        .hero-content {
            text-align: center;
            z-index: 3;
            position: relative;
        }

        /* Residem-style: full-height hero + bottom meta bar (colors unchanged) */
        .hero.hero--residem {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            justify-content: flex-end;
            min-height: 92vh;
            padding-bottom: 0;
            padding-top: 100px;
        }

        .hero.hero--residem .hero-copy {
            position: relative;
            z-index: 3;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px 36px;
            box-sizing: border-box;
        }

        .hero.hero--residem .hero-content--left {
            text-align: left;
            max-width: 640px;
            margin: 0;
        }

        .hero.hero--residem .hero-title {
            font-size: clamp(2rem, 5vw, 3.25rem);
        }

        .hero.hero--residem .search-container {
            margin: 0;
            max-width: 560px;
        }

        .hero.hero--residem .rr-hero-bottom-bar {
            margin-top: 0;
            border-radius: 0;
        }

        @media (max-width: 768px) {
            .hero.hero--residem .hero-content--left {
                text-align: center;
                margin-left: auto;
                margin-right: auto;
            }

            .hero.hero--residem .search-container {
                margin-left: auto;
                margin-right: auto;
            }
        }

        .hero-title {
            font-size: 48px;
            font-weight: bold;
            margin-bottom: 20px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.6);
            color: white;
        }

        .hero-subtitle {
            font-size: 20px;
            margin-bottom: 40px;
            opacity: 0.95;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
            color: white;
        }

        .search-container {
            display: flex;
            max-width: 600px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .search-input {
            flex: 1;
            padding: 20px 25px;
            border: none;
            outline: none;
            font-size: 16px;
            color: #333;
        }

        .search-input::placeholder {
            color: #999;
        }

        .search-btn {
            background: #20b2aa;
            color: white;
            border: none;
            padding: 20px 30px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .search-btn:hover {
            background: #008b8b;
        }

        /* Furniture Decorations */
        .furniture-section {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 200px;
            display: flex;
            align-items: end;
            justify-content: center;
            gap: 40px;
            padding: 0 20px;
            z-index: 1;
        }

        .furniture-group {
            display: flex;
            align-items: end;
            gap: 20px;
        }

        .chair {
            width: 60px;
            height: 80px;
            background: #4a9eff;
            border-radius: 10px 10px 0 0;
            position: relative;
        }

        .chair::after {
            content: '';
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            height: 20px;
            background: #ff6b35;
            border-radius: 5px;
        }

        .sofa {
            width: 120px;
            height: 60px;
            background: #f5f5dc;
            border-radius: 10px;
            position: relative;
        }

        .sofa::before {
            content: '';
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            height: 15px;
            background: #ff6b35;
            border-radius: 5px;
        }

        .sofa::after {
            content: '';
            position: absolute;
            top: 10px;
            right: 20px;
            width: 15px;
            height: 15px;
            background: #4a9eff;
            border-radius: 5px;
        }

        .table {
            width: 40px;
            height: 30px;
            background: #8b4513;
            border-radius: 5px;
            position: relative;
        }

        .table::before {
            content: '';
            position: absolute;
            top: -5px;
            left: 5px;
            right: 5px;
            height: 5px;
            background: #654321;
            border-radius: 2px;
        }

        .plant {
            width: 30px;
            height: 60px;
            background: #4ade80;
            border-radius: 15px 15px 0 0;
            position: relative;
        }

        .plant::before {
            content: '';
            position: absolute;
            top: -10px;
            left: 5px;
            right: 5px;
            height: 20px;
            background: #2d6a7a;
            border-radius: 10px;
        }

        /* Management Section */
        .management-section {
            background: white;
            color: #333;
            padding: 60px 0;
        }

        .management-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .management-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .management-title {
            font-size: 36px;
            color: #1a4b5c;
            margin-bottom: 15px;
        }

        .management-subtitle {
            font-size: 18px;
            color: #666;
            margin-bottom: 30px;
        }

        .management-actions {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 15px 30px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-block;
        }

        .management-section .btn-primary {
            background: #20b2aa;
            color: white;
        }

        .management-section .btn-primary:hover {
            background: #008b8b;
            transform: translateY(-2px);
        }

        .management-section .btn-success {
            background: #008b8b;
            color: white;
        }

        .management-section .btn-success:hover {
            background: #0d7373;
            transform: translateY(-2px);
        }

        /* Units Section */
        .units-section {
            background: white;
            color: #333;
            padding: 80px 0;
        }

        .units-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .section-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .section-title {
            font-size: 42px;
            color: #1a4b5c;
            margin-bottom: 15px;
            font-weight: bold;
        }

        .section-subtitle {
            font-size: 18px;
            color: #666;
        }

        .units-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        .unit-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
        }

        .unit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .unit-image {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

        .unit-content {
            padding: 20px;
        }

        .unit-name {
            font-size: 22px;
            font-weight: bold;
            color: #1a4b5c;
            margin-bottom: 10px;
        }

        .unit-address {
            color: #666;
            font-size: 14px;
            margin-bottom: 15px;
        }

        .unit-details {
            display: flex;
            gap: 20px;
            margin-bottom: 15px;
            font-size: 14px;
            color: #666;
        }

        .unit-price {
            font-size: 24px;
            font-weight: bold;
            color: #20b2aa;
            margin-bottom: 15px;
        }

        .unit-status {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-available {
            background: #d4edda;
            color: #155724;
        }

        .status-occupied {
            background: #fff3cd;
            color: #856404;
        }

        /* Feedbacks Section */
        .feedbacks-section {
            background: linear-gradient(135deg, #0a1a2e, #16213e);
            color: white;
            padding: 80px 0;
        }

        .feedbacks-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .feedbacks-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }

        .feedback-card {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .feedback-text {
            font-size: 16px;
            line-height: 1.8;
            margin-bottom: 20px;
            font-style: italic;
        }

        .feedback-author {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .feedback-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #20b2aa;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
        }

        .feedback-author-info {
            flex: 1;
        }

        .feedback-author-name {
            font-weight: 600;
            margin-bottom: 5px;
        }

        .feedback-author-role {
            font-size: 14px;
            opacity: 0.8;
        }

        .feedback-rating {
            color: #ffd700;
            font-size: 18px;
        }

        /* News Section */
        .news-section {
            background: white;
            color: #333;
            padding: 80px 0;
        }

        .news-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 30px;
            margin-top: 50px;
        }

        .news-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .news-card:hover {
            transform: translateY(-5px);
        }

        .news-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: linear-gradient(135deg, #20b2aa, #008b8b);
        }

        .news-content {
            padding: 25px;
        }

        .news-date {
            color: #20b2aa;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .news-title {
            font-size: 20px;
            font-weight: bold;
            color: #1a4b5c;
            margin-bottom: 10px;
        }

        .news-excerpt {
            color: #666;
            font-size: 14px;
            line-height: 1.6;
        }

        /* Contacts Section */
        .contacts-section {
            background: linear-gradient(135deg, #1a4b5c, #2d6a7a);
            color: white;
            padding: 80px 0;
        }

        .contacts-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .contacts-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            margin-top: 50px;
        }

        .contact-info {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .contact-item {
            display: flex;
            align-items: start;
            gap: 20px;
        }

        .contact-icon {
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }

        .contact-details h3 {
            font-size: 20px;
            margin-bottom: 8px;
        }

        .contact-details p {
            font-size: 16px;
            opacity: 0.9;
            line-height: 1.6;
        }

        .contact-form {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 16px;
            font-family: inherit;
        }

        .form-group input::placeholder,
        .form-group textarea::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .submit-btn {
            background: #20b2aa;
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .submit-btn:hover {
            background: #008b8b;
            transform: translateY(-2px);
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 32px;
            }
            
            .hero-subtitle {
                font-size: 16px;
            }
            
            .search-container {
                flex-direction: column;
                border-radius: 15px;
            }
            
            .search-input {
                border-radius: 15px 15px 0 0;
            }
            
            .search-btn {
                border-radius: 0 0 15px 15px;
            }
            
            .rewards-container {
                flex-direction: column;
                gap: 20px;
                text-align: center;
            }
            
            .furniture-section {
                display: none;
            }

            .units-grid {
                grid-template-columns: 1fr;
            }

            .feedbacks-grid {
                grid-template-columns: 1fr;
            }

            .news-grid {
                grid-template-columns: 1fr;
            }

            .contacts-content {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 480px) {
            .rewards-title {
                font-size: 1.35rem;
            }

            .rewards-text {
                flex-direction: column;
                align-items: center;
                gap: 12px;
                text-align: center;
            }

            .rewards-features {
                flex-wrap: wrap;
                justify-content: center;
            }

            .hero.hero--residem {
                min-height: min(88vh, 720px);
                padding-top: 88px;
            }

            .hero-title {
                font-size: clamp(1.5rem, 7vw, 2rem);
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
{% endblock %}

{% block body %}
<!-- Hero (Residem-style: full-height hero + bottom property bar) -->
<section class="hero hero--residem">
    <div class="hero-copy">
        <div class="hero-content hero-content--left">
            <h1 class="hero-title">Rent your happy place</h1>
            <p class="hero-subtitle">Quality apartments and responsive property management across the Pacific Northwest—transparent leasing, well-maintained homes.</p>
            <div class="search-container">
                <input type="text" class="search-input" placeholder="Where are you moving? What are you looking for?" aria-label="Search rentals" />
                <button type="button" class="search-btn">Search</button>
            </div>
        </div>
    </div>
    <div class="rr-hero-bottom-bar">
        <div class="rr-hero-bottom-bar__grid">
            <div class="rr-hero-bottom-item">
                <span class="rr-hero-bottom-item__label">Units</span>
                <span class="rr-hero-bottom-item__value">Studio to 3BR</span>
            </div>
            <div class="rr-hero-bottom-item">
                <span class="rr-hero-bottom-item__label">Support</span>
                <span class="rr-hero-bottom-item__value">24/7</span>
            </div>
            <div class="rr-hero-bottom-item">
                <span class="rr-hero-bottom-item__label">Listings</span>
                <span class="rr-hero-bottom-item__value">100% verified</span>
            </div>
            <div class="rr-hero-bottom-item">
                <span class="rr-hero-bottom-item__label">Region</span>
                <span class="rr-hero-bottom-item__value">Pacific NW</span>
            </div>
        </div>
    </div>
</section>

<!-- Split intro (property “about” block) -->
<section class="rr-section rr-section--white">
    <div class="rr-wrap">
        <div class="rr-split">
            <div class="rr-split__media">
                <img src="{{ asset('img/apt2.jpg') }}" alt="Modern apartment living space" loading="lazy" width="800" height="600" />
            </div>
            <div class="rr-split__body">
                <p class="rr-kicker">About our community</p>
                <h2 class="rr-section-title">Designed for modern renters</h2>
                <p class="rr-section-sub">We focus on clear communication, fair leases, and spaces you&apos;re proud to call home.</p>
                <ul class="rr-list-check">
                    <li>Online applications and digital lease workflows</li>
                    <li>Proactive maintenance and vendor coordination</li>
                    <li>Local team with deep neighborhood knowledge</li>
                </ul>
                <a href="{{ path('app_about_index') }}" class="rr-link-arrow">Learn more about us &rarr;</a>
            </div>
        </div>
    </div>
</section>

<!-- Amenities -->
<section class="rr-section rr-section--light rr-section--tight">
    <div class="rr-wrap">
        <p class="rr-kicker" style="text-align: center;">Amenities</p>
        <h2 class="rr-section-title" style="text-align: center;">What you&apos;ll find</h2>
        <p class="rr-section-sub" style="text-align: center; margin-left: auto; margin-right: auto;">Common highlights across our portfolio—exact amenities vary by building.</p>
        <div class="rr-amenities">
            <div class="rr-amenity"><div class="rr-amenity__icon" aria-hidden="true">&#128663;</div><div class="rr-amenity__text">Parking</div></div>
